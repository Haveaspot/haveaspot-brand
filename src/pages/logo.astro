---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Logo System" section="logo">
  <div class="page-hero">
    <span class="page-num">02 — Logo System</span>
    <h1 class="page-title">Logo System</h1>
    <p class="page-intro">
      The Haveaspot logo is our most recognisable brand asset. These guidelines ensure it is used
      consistently and with care across every context.
    </p>
  </div>

  <div class="page-body">

    <!-- Primary Logo -->
    <div class="block">
      <h2 class="block-title">Primary Logo</h2>
      <p class="block-desc">
        The primary logo is the wordmark lockup — the Haveaspot name with the brand mark.
        Always use the master files from the asset library. Never recreate the logo in type.
      </p>
      <div class="logo-showcase-grid">
        <div class="logo-tile logo-tile--dark">
          <div class="logo-placeholder">
            <img src="/logo-on-dark.svg" alt="Haveaspot Logo" class="logo-tile-img" />
          </div>
          <span class="logo-tile-label">Primary — on dark</span>
        </div>
        <div class="logo-tile logo-tile--light">
          <div class="logo-placeholder">
            <img src="/logo.webp" alt="Haveaspot Logo" class="logo-tile-img" />
          </div>
          <span class="logo-tile-label">Primary — on white</span>
        </div>
        <div class="logo-tile logo-tile--surface">
          <div class="logo-placeholder">
            <img src="/logo.webp" alt="Haveaspot Logo" class="logo-tile-img" />
          </div>
          <span class="logo-tile-label">Primary — on light surface</span>
        </div>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Secondary Logo -->
    <div class="block">
      <h2 class="block-title">Secondary Logo</h2>
      <p class="block-desc">
        The secondary treatment is a single-colour monochrome wordmark, used when the two-tone primary
        lockup doesn't have enough contrast against its background. White on brand green, white on dark,
        or solid #021300 on white — never mix colours within the mark itself.
      </p>
      <div class="logo-showcase-grid">
        <div class="logo-tile logo-tile--green">
          <div class="logo-placeholder">
            <img src="/logo.webp" alt="Haveaspot Logo" class="logo-tile-img logo-tile-img--invert" />
          </div>
          <span class="logo-tile-label">Secondary — on brand green</span>
        </div>
        <div class="logo-tile logo-tile--dark">
          <div class="logo-placeholder">
            <img src="/logo.webp" alt="Haveaspot Logo" class="logo-tile-img logo-tile-img--invert" />
          </div>
          <span class="logo-tile-label">Secondary — on dark</span>
        </div>
        <div class="logo-tile logo-tile--light">
          <div class="logo-placeholder">
            <img src="/logo-mono-dark.svg" alt="Haveaspot Logo" class="logo-tile-img" />
          </div>
          <span class="logo-tile-label">Secondary — on white</span>
        </div>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Clear Space -->
    <div class="block">
      <h2 class="block-title">Clear Space</h2>
      <p class="block-desc">
        Always maintain clear space around the logo equal to the height of the letter 'H' in the wordmark.
        No other elements, text, or imagery should enter this zone.
      </p>
      <div class="clearspace-demo">
        <div class="cs-outer">
          <div class="cs-inner">
            <img src="/logo.webp" alt="Haveaspot Logo" class="cs-logo" />
          </div>
        </div>
        <p class="cs-caption">The dashed border represents the minimum clear space zone</p>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Minimum Size -->
    <div class="block">
      <h2 class="block-title">Minimum Size</h2>
      <p class="block-desc">
        To maintain legibility, never reproduce the logo smaller than the sizes specified below.
      </p>
      <div class="size-row">
        <div class="size-item">
          <div class="size-demo size-demo--120">
            <img src="/logo.webp" alt="Haveaspot Logo" style="height: 24px; width: auto; display: block; object-fit: contain;" />
          </div>
          <span class="size-label">Digital minimum — 120px wide</span>
        </div>
        <div class="size-item">
          <div class="size-demo size-demo--32">
            <img src="/favicon.svg" alt="Haveaspot Icon" style="height: 32px; width: 32px; display: block;" />
          </div>
          <span class="size-label">Favicon / icon minimum — 32px</span>
        </div>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Incorrect Usage -->
    <div class="block">
      <h2 class="block-title">Incorrect Usage</h2>
      <p class="block-desc">
        These examples show what not to do. The logo must never be altered, distorted, or placed on backgrounds
        that reduce legibility.
      </p>
      <div class="dont-grid">
        <div class="dont-item">
          <div class="dont-tile dont-tile--stretched">
            <span class="lp-wordmark lp-wordmark--dark" style="transform: scaleX(1.4); display:inline-block;">Haveaspot</span>
          </div>
          <p class="dont-label">✗ Don't stretch or distort</p>
        </div>
        <div class="dont-item">
          <div class="dont-tile dont-tile--lowcontrast">
            <span class="lp-wordmark" style="color: rgba(255,255,255,0.25);">Haveaspot</span>
          </div>
          <p class="dont-label">✗ Don't use on low-contrast backgrounds</p>
        </div>
        <div class="dont-item">
          <div class="dont-tile dont-tile--coloured">
            <span class="lp-wordmark" style="color: #e53e3e;">Haveaspot</span>
          </div>
          <p class="dont-label">✗ Don't recolour the wordmark</p>
        </div>
        <div class="dont-item">
          <div class="dont-tile dont-tile--rotated">
            <span class="lp-wordmark lp-wordmark--dark" style="transform: rotate(-15deg); display:inline-block;">Haveaspot</span>
          </div>
          <p class="dont-label">✗ Don't rotate or tilt</p>
        </div>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Downloads -->
    <div class="block">
      <h2 class="block-title">Logo Assets</h2>
      <p class="block-desc">
        All logo files are maintained in the Haveaspot Google Drive asset library.
        Always use the files from this library — never export or recreate the logo yourself.
      </p>
      <a href="https://drive.google.com/drive/u/0/folders/1gzTSBvjuhShy0lzH08Hji2u7Y7o_Stch" target="_blank" rel="noopener noreferrer" class="asset-link-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Open Logo Asset Library
      </a>
      <div class="asset-formats">
        <div class="format-item"><span class="format-ext">SVG</span><span class="format-desc">Recommended for web and digital use</span></div>
        <div class="format-item"><span class="format-ext">PNG</span><span class="format-desc">For presentations and documents (transparent background)</span></div>
        <div class="format-item"><span class="format-ext">PDF</span><span class="format-desc">For print production</span></div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .logo-showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .logo-tile {
    border-radius: 12px;
    padding: 3rem 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    min-width: 0;
  }
  .logo-tile-label {
    white-space: normal;
  }
  .logo-tile--dark    { background: #021300; }
  .logo-tile--light   { background: #fff; border: 2px solid #E5E7EB; }
  .logo-tile--green   { background: #0AAD0A; }
  .logo-tile--surface { background: #F9FAFB; border: 1px solid #E5E7EB; }

  .logo-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60px;
    width: 100%;
  }
  .logo-tile-img {
    width: 100%;
    max-width: 180px;
    height: auto;
    display: block;
    object-fit: contain;
  }
  .logo-tile-img--invert {
    filter: brightness(0) invert(1);
  }
  .cs-logo {
    height: 32px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .logo-tile-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    align-self: center;
  }
  .logo-tile--light .logo-tile-label,
  .logo-tile--surface .logo-tile-label {
    color: rgba(2,19,0,0.4);
  }

  .clearspace-demo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .cs-outer {
    border: 2px dashed #0AAD0A;
    border-radius: 4px;
    padding: 2.5rem 3rem;
    display: inline-flex;
  }
  .cs-inner {
    border: 1px solid #E5E7EB;
    border-radius: 4px;
    padding: 1rem 1.5rem;
    background: #fff;
  }
  .cs-caption {
    font-size: 0.8rem;
    font-weight: 300;
    color: #021300;
  }

  .size-row {
    display: flex;
    gap: 3rem;
    align-items: flex-end;
  }
  .size-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .size-demo {
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
  }
  .size-demo--120 { width: 140px; }
  .size-demo--32  { width: 64px; }
  .size-label {
    font-size: 0.75rem;
    font-weight: 300;
    color: #021300;
  }

  .dont-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .dont-item { display: flex; flex-direction: column; gap: 0.75rem; }
  .dont-tile {
    border-radius: 10px;
    padding: 2.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100px;
    border: 2px solid transparent;
  }
  .dont-tile--stretched  { background: #F9FAFB; border-color: #E5E7EB; }
  .dont-tile--lowcontrast { background: #333; }
  .dont-tile--coloured   { background: #F9FAFB; border-color: #E5E7EB; }
  .dont-tile--rotated    { background: #F9FAFB; border-color: #E5E7EB; overflow: hidden; }
  .dont-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: #e53e3e;
  }

  .asset-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 44px;
    padding: 0 1.5rem;
    background: #021300;
    color: #fff;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s ease;
    margin-bottom: 2rem;
  }
  .asset-link-btn:hover { background: #0AAD0A; }

  .asset-formats {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .format-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .format-ext {
    font-size: 0.7rem;
    font-weight: 700;
    color: #021300;
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    border-radius: 4px;
    padding: 2px 8px;
    letter-spacing: 0.05em;
    min-width: 44px;
    text-align: center;
  }
  .format-desc {
    font-size: 0.875rem;
    font-weight: 300;
    color: #021300;
  }

  @media (max-width: 700px) {
    .logo-showcase-grid, .dont-grid { grid-template-columns: 1fr; }
    .size-row { flex-direction: column; gap: 1.5rem; }
  }
</style>
