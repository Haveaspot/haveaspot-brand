---
import BaseLayout from '../layouts/BaseLayout.astro';

const logoAssets = [
  {
    name: 'Primary Logo — Dark',
    note: 'White wordmark for dark and coloured backgrounds',
    preview: { src: '/downloads/logo-primary-dark.svg', bg: '#021300', border: false },
    files: [
      { label: 'SVG', href: '/downloads/logo-primary-dark.svg', ready: true },
      { label: 'PNG', href: '/downloads/logo-primary-dark.png', ready: true },
    ],
  },
  {
    name: 'Primary Logo — Light',
    note: 'Dark wordmark for white and light backgrounds',
    preview: { src: '/downloads/logo-primary-light.svg', bg: '#F9FAFB', border: true },
    files: [
      { label: 'SVG', href: '/downloads/logo-primary-light.svg', ready: true },
      { label: 'PNG', href: '/downloads/logo-primary-light.png', ready: true },
    ],
  },
  {
    name: 'Icon / Mark Only',
    note: 'For favicon, app icon, and small-format use',
    preview: { src: '/downloads/logo-icon.svg', bg: '#F9FAFB', border: true, circle: true },
    files: [
      { label: 'SVG', href: '/downloads/logo-icon.svg', ready: true },
      { label: 'PNG', href: '/downloads/logo-icon.png', ready: true },
    ],
  },
  {
    name: 'Logo — Mono White',
    note: 'Single-colour white for print and embossing',
    preview: { src: '/downloads/logo-mono-white.svg', bg: '#021300', border: false },
    files: [
      { label: 'SVG', href: '/downloads/logo-mono-white.svg', ready: true },
      { label: 'PNG', href: '/downloads/logo-mono-white.png', ready: true },
    ],
  },
  {
    name: 'Logo — Mono Dark',
    note: 'Single-colour dark for print and embossing',
    preview: { src: '/downloads/logo-mono-dark.svg', bg: '#F9FAFB', border: true },
    files: [
      { label: 'SVG', href: '/downloads/logo-mono-dark.svg', ready: true },
      { label: 'PNG', href: '/downloads/logo-mono-dark.png', ready: true },
    ],
  },
];

const colourAssets = [
  {
    name: 'CSS Variables',
    note: 'Design token block — drop into your project global CSS',
    files: [
      { label: 'CSS', href: '/downloads/haveaspot-css-variables.css', ready: true },
    ],
  },
  {
    name: 'Colour Palette',
    note: 'Full palette with hex values, RGB values, and usage rules',
    files: [
      { label: 'PDF', href: '/downloads/haveaspot-colour-palette.pdf', ready: true },
    ],
  },
];

const typographyAssets = [
  {
    name: 'Poppins — Google Fonts',
    note: 'fonts.google.com/specimen/Poppins',
    files: [
      { label: 'Open', href: 'https://fonts.google.com/specimen/Poppins', ready: true, external: true },
    ],
  },
  {
    name: 'Poppins — @fontsource',
    note: 'npm install @fontsource/poppins',
    files: [
      { label: 'npm', href: 'https://www.npmjs.com/package/@fontsource/poppins', ready: true, external: true },
    ],
  },
];
---

<BaseLayout title="Downloads" section="downloads">
  <div class="page-hero">
    <span class="page-num">08 — Downloads</span>
    <h1 class="page-title">Downloads</h1>
    <p class="page-intro">
      Brand assets ready to use. Logo files should always be taken from here — never recreated or altered independently.
    </p>
  </div>

  <div class="page-body">

    <!-- Logo Files -->
    <div class="block">
      <h2 class="block-title">Logo Files</h2>
      <p class="block-desc">Master logo files in all approved formats. Always use these — never recreate the logo in type.</p>
      <div class="asset-list">
        {logoAssets.map(asset => (
          <div class="asset-row">
            <div class="asset-info">
              <span class="asset-name">{asset.name}</span>
              <span class="asset-note">{asset.note}</span>
            </div>
            <div
              class={`logo-pill${asset.preview.circle ? ' logo-pill--circle' : ''}`}
              style={`background:${asset.preview.bg};${asset.preview.border ? ' border:1px solid #E5E7EB;' : ''}`}
            >
              <img src={asset.preview.src} alt={asset.name} class="logo-pill-img" />
            </div>
            <div class="asset-actions">
              {asset.files.map(f => (
                f.ready
                  ? <a href={f.href} download class="dl-btn dl-btn--ready">
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      {f.label}
                    </a>
                  : <span class="dl-btn dl-btn--pending" title={`Add ${f.href.split('/').pop()} to public/downloads/`}>
                      {f.label}
                    </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Colour -->
    <div class="block">
      <h2 class="block-title">Colour Swatches</h2>
      <p class="block-desc">Brand colour tokens for design tools and code.</p>
      <div class="asset-list">
        {colourAssets.map(asset => (
          <div class="asset-row">
            <div class="asset-info">
              <span class="asset-name">{asset.name}</span>
              <span class="asset-note">{asset.note}</span>
            </div>
            <div class="asset-spacer"></div>
            <div class="asset-actions">
              {asset.files.map(f => (
                f.ready
                  ? <a href={f.href} download={!f.external || undefined} target={f.external ? '_blank' : undefined} rel={f.external ? 'noopener noreferrer' : undefined} class="dl-btn dl-btn--ready">
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      {f.label}
                    </a>
                  : <span class="dl-btn dl-btn--pending">{f.label}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Typography -->
    <div class="block">
      <h2 class="block-title">Typography</h2>
      <p class="block-desc">Poppins is available via Google Fonts and @fontsource. No download required for web use.</p>
      <div class="asset-list">
        {typographyAssets.map(asset => (
          <div class="asset-row">
            <div class="asset-info">
              <span class="asset-name">{asset.name}</span>
              <span class="asset-note">{asset.note}</span>
            </div>
            <div class="asset-spacer"></div>
            <div class="asset-actions">
              {asset.files.map(f => (
                <a href={f.href} target="_blank" rel="noopener noreferrer" class="dl-btn dl-btn--ready">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  {f.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Usage Policy -->
    <div class="block">
      <h2 class="block-title">Usage & Permissions</h2>
      <p class="block-desc">
        Who can use Haveaspot brand assets, and under what conditions. If you're unsure whether your use
        case is covered, ask before you publish.
      </p>
      <div class="policy-list">
        {[
          ['Internal use',      'All Haveaspot team members may access and use brand assets for business purposes.'],
          ['Agency partners',   'Approved agencies may access assets for active Haveaspot projects. Do not share with third parties.'],
          ['External use',      'Any external use of the Haveaspot logo or brand must be approved by the founding team before publication.'],
          ['Alterations',       'Brand assets must not be altered, recoloured, distorted, or recreated. Use master files only.'],
          ['Requesting access', 'Email the team to request access to the asset library or to report an incorrect usage.'],
        ].map(([k, v]) => (
          <div class="policy-row">
            <span class="policy-key">{k}</span>
            <span class="policy-val">{v}</span>
          </div>
        ))}
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Developer Reference -->
    <div class="block">
      <h2 class="block-title">Developer Reference</h2>
      <p class="block-desc">The full developer brand guide lives alongside this site as a Markdown file in GitHub.</p>
      <a
        href="https://github.com/Haveaspot/haveaspot-brand/blob/main/BRAND.md"
        target="_blank"
        rel="noopener noreferrer"
        class="gh-link"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.28-.01-1.03-.01-2.03-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3.01-.4c1.02.01 2.05.14 3.01.4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22 0 1.6-.01 2.9-.01 3.29 0 .32.21.7.82.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View BRAND.md on GitHub
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .upload-note {
    font-size: 0.8rem;
    font-weight: 300;
    color: rgba(2,19,0,0.5);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }
  .upload-note code {
    font-family: 'Courier New', monospace;
    font-size: 0.75rem;
    background: rgba(2,19,0,0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .master-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.5rem;
    background: #021300;
    border-radius: 12px;
    flex-wrap: wrap;
  }
  .mc-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .mc-icon {
    width: 52px;
    height: 52px;
    background: rgba(10,173,10,0.15);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0AAD0A;
    flex-shrink: 0;
  }
  .mc-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.2rem;
  }
  .mc-desc {
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(255,255,255,0.6);
  }
  .mc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 44px;
    padding: 0 1.5rem;
    background: #0AAD0A;
    color: #fff;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }
  .mc-btn:hover { background: #0E491F; color: #fff; }

  .asset-list {
    display: flex;
    flex-direction: column;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    overflow: hidden;
  }
  .asset-row {
    display: grid;
    grid-template-columns: 1fr 160px 1fr;
    align-items: center;
    gap: 2rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #E5E7EB;
  }
  .asset-row:last-child { border-bottom: none; }
  .asset-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .asset-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: #021300;
  }
  .asset-note {
    font-size: 0.78rem;
    font-weight: 300;
    color: rgba(2,19,0,0.5);
  }
  .logo-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    padding: 0.45rem 1.1rem;
    width: 160px;
    flex-shrink: 0;
  }
  .logo-pill--circle {
    width: 44px;
    height: 44px;
    padding: 0;
    border-radius: 50%;
    margin: 0 auto;
    overflow: hidden;
  }
  .logo-pill--circle .logo-pill-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    -webkit-mask-image: radial-gradient(circle, black 100%, transparent 100%);
    mask-image: radial-gradient(circle, black 100%, transparent 100%);
  }
  .logo-pill-img {
    height: 20px;
    width: auto;
    display: block;
  }
  .asset-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    flex-shrink: 0;
    justify-self: end;
  }
  .asset-spacer {
    width: 160px;
  }
  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 5px;
    padding: 5px 10px;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }
  .dl-btn--ready {
    background: #021300;
    color: #fff;
    cursor: pointer;
  }
  .dl-btn--ready:hover {
    background: #0AAD0A;
    color: #fff;
  }
  .dl-btn--pending {
    background: #F9FAFB;
    color: rgba(2,19,0,0.35);
    border: 1px solid #E5E7EB;
    cursor: default;
  }

  .policy-list {
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    overflow: hidden;
  }
  .policy-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1rem;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid #E5E7EB;
    font-size: 0.875rem;
    align-items: start;
  }
  .policy-row:last-child { border-bottom: none; }
  .policy-key { font-weight: 600; color: #021300; }
  .policy-val { font-weight: 300; color: #021300; line-height: 1.6; }

  .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    height: 44px;
    padding: 0 1.5rem;
    background: #021300;
    color: #fff;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .gh-link:hover { background: #0AAD0A; color: #fff; }

  @media (max-width: 700px) {
    .master-cta { flex-direction: column; align-items: flex-start; }
    .policy-row { grid-template-columns: 1fr; }
  }
</style>
