---
import BaseLayout from '../layouts/BaseLayout.astro';

const values = [
  {
    name: 'Community',
    desc: 'Everything we build is in service of local people and local spaces. We exist to strengthen the social fabric of communities, not to extract value from them.',
  },
  {
    name: 'Simplicity',
    desc: '"Simplicity and Reliability" is our explicit product philosophy. Complexity is the enemy. Every feature must be intuitive to a passionate, non-technical volunteer.',
  },
  {
    name: 'Empowerment',
    desc: 'Venues gain world-class tools at zero cost. Bookers gain instant confidence. We level the playing field — giving community organisations the same digital capabilities as large commercial operators.',
  },
  {
    name: 'Authenticity',
    desc: 'We are personal, warm, and genuine. We celebrate village halls, not boardrooms. Our relationships are built on trust and genuine care, never on corporate distance.',
  },
  {
    name: 'Trust',
    desc: 'Every booking is confirmed, every payment is secure, every experience is reliable. Trust is not a feature — it is the foundation of everything we do.',
  },
];
---

<BaseLayout title="Brand Foundation" section="foundation">
  <div class="page-hero">
    <span class="page-num">01 — Brand Foundation</span>
    <h1 class="page-title">Who we are<br/>and why it matters.</h1>
    <p class="page-intro">
      The foundation sets out the beliefs, purpose, and principles that drive every decision at Haveaspot —
      from product choices to the way we write an email.
    </p>
  </div>

  <div class="page-body">

    <!-- Mission -->
    <div class="block">
      <h2 class="block-title">Mission</h2>
      <p class="block-desc">The single reason we exist.</p>
      <div class="statement-card">
        <p class="statement-text">
          To become the definitive booking platform for community spaces — empowering volunteer-run venues
          with world-class technology, free of charge.
        </p>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Vision -->
    <div class="block">
      <h2 class="block-title">Vision</h2>
      <p class="block-desc">The future we're building towards.</p>
      <div class="statement-card">
        <p class="statement-text">
          A world where every community space thrives — where the village hall down the road is as easy to
          find and book as a hotel, and where local spaces are the beating heart of every neighbourhood.
        </p>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Positioning -->
    <div class="block">
      <h2 class="block-title">Brand Positioning</h2>
      <p class="block-desc">How we define ourselves relative to everyone else.</p>
      <div class="positioning-block">
        <div class="positioning-tag">In one line</div>
        <p class="positioning-line">"Purpose-built for the village hall, not the city photography studio."</p>
      </div>
      <p class="positioning-body">
        Haveaspot wins not by being the most complex platform, but by being the most human one. Our competitors
        target enterprise clients and high-end commercial venues. We serve the passionate, time-poor volunteer
        committee running a community asset for the good of their village. That focus is not a limitation — it
        is our competitive advantage.
      </p>
      <div class="positioning-comparisons">
        <div class="comp-row">
          <span class="comp-label">We are</span>
          <span class="comp-value comp-yes">Simple, human, free for venues</span>
        </div>
        <div class="comp-row">
          <span class="comp-label">We are not</span>
          <span class="comp-value comp-no">Enterprise software, city-focused, complex</span>
        </div>
        <div class="comp-row">
          <span class="comp-label">Our analogy</span>
          <span class="comp-value comp-yes">Airbnb — but for community spaces</span>
        </div>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Values -->
    <div class="block">
      <h2 class="block-title">Brand Values</h2>
      <p class="block-desc">
        Five principles that guide every product decision, every piece of writing, and every interaction with our users.
      </p>
      <ul class="values-list">
        {values.map((v, i) => (
          <li class="value-card">
            <span class="value-num">0{i + 1}</span>
            <div class="value-content">
              <h3 class="value-name">{v.name}</h3>
              <p class="value-desc">{v.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <hr class="section-rule" />

    <!-- Target Audiences -->
    <div class="block">
      <h2 class="block-title">Who We Serve</h2>
      <p class="block-desc">Two distinct audiences. One platform.</p>
      <div class="audience-grid">
        <div class="audience-card">
          <h3 class="audience-label">Venues (Supply)</h3>
          <p class="audience-desc">
            Volunteer-run community organisations — village hall committees, community centres, charity trustees.
            Time-poor, non-technical, motivated by purpose rather than profit. They need tools that save time and
            increase revenue without adding complexity.
          </p>
          <ul class="audience-needs">
            <li>Free to list and manage</li>
            <li>Simple enough for a volunteer</li>
            <li>Online payments and real-time availability</li>
            <li>Less admin, more community impact</li>
          </ul>
        </div>
        <div class="audience-card">
          <h3 class="audience-label">Bookers (Demand)</h3>
          <p class="audience-desc">
            Local residents and organisations — primarily Millennials and Gen X — looking for accessible,
            affordable spaces for events, classes, and gatherings. Digitally native, frustrated by the current
            friction of phone calls and email chains.
          </p>
          <ul class="audience-needs">
            <li>Discover spaces easily</li>
            <li>Instant booking confirmation</li>
            <li>Secure online payment</li>
            <li>Confidence and peace of mind</li>
          </ul>
        </div>
      </div>
    </div>

    <hr class="section-rule" />

    <!-- Future Direction -->
    <div class="block">
      <h2 class="block-title">Future Direction</h2>
      <p class="block-desc">
        Our roadmap extends beyond today's core market — the brand should stretch with it, not be rewritten by it.
      </p>
      <div class="future-grid">
        <div class="future-card">
          <span class="future-label">Vertical Expansion</span>
          <p class="future-text">
            Schools, local councils, and independent commercial venues join village halls and community
            centres over time. The tone changes by audience, but the promise — free simplicity for venues,
            instant trust for bookers — does not.
          </p>
        </div>
        <div class="future-card">
          <span class="future-label">Revenue Diversification</span>
          <p class="future-text">
            Advertising, recurring bookings, and ticketing extend the platform without diluting it. Every
            new module earns its place only if it stays true to "Simplicity and Reliability."
          </p>
        </div>
        <div class="future-card">
          <span class="future-label">Geographic Expansion</span>
          <p class="future-text">
            Australia follows once the UK market is proven. Same playbook, same values, same voice —
            adapted, never diluted, for a new market.
          </p>
        </div>
      </div>
      <p class="future-footnote">
        This is direction, not a current claim. Brand language should describe who we serve today —
        update Mission, Positioning, and Who We Serve as each new vertical or market actually launches.
      </p>
    </div>

  </div>
</BaseLayout>

<style>
  .statement-card {
    background: #021300;
    border-radius: 12px;
    padding: 2.5rem 3rem;
  }
  .statement-text {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 300;
    color: #fff;
    line-height: 1.65;
    font-style: italic;
  }

  .positioning-block {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .positioning-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: #0AAD0A;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }
  .positioning-line {
    font-size: 1.25rem;
    font-weight: 700;
    color: #021300;
    line-height: 1.3;
  }
  .positioning-body {
    font-size: 1rem;
    font-weight: 300;
    color: #021300;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 44rem;
  }
  .positioning-comparisons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-left: 3px solid #0AAD0A;
    padding-left: 1.5rem;
  }
  .comp-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .comp-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(2,19,0,0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    min-width: 80px;
  }
  .comp-value {
    font-size: 0.95rem;
    font-weight: 500;
  }
  .comp-yes { color: #021300; }
  .comp-no  { color: rgba(2,19,0,0.4); text-decoration: line-through; }

  .values-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .value-card {
    display: flex;
    gap: 1.75rem;
    padding: 1.75rem 2rem;
    border: 2px solid #021300;
    border-radius: 12px;
    align-items: flex-start;
    transition: border-color 0.2s ease;
  }
  .value-card:hover { border-color: #0AAD0A; }
  .value-num {
    font-size: 0.7rem;
    font-weight: 600;
    color: #0AAD0A;
    letter-spacing: 0.08em;
    padding-top: 0.2rem;
    min-width: 1.5rem;
  }
  .value-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #021300;
    margin-bottom: 0.4rem;
  }
  .value-desc {
    font-size: 0.9rem;
    font-weight: 300;
    color: #021300;
    line-height: 1.65;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .audience-card {
    padding: 2rem;
    background: #F9FAFB;
    border-radius: 12px;
    border: 1px solid #E5E7EB;
  }
  .audience-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #0AAD0A;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .audience-desc {
    font-size: 0.9rem;
    font-weight: 300;
    color: #021300;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }
  .audience-needs {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .audience-needs li {
    font-size: 0.875rem;
    font-weight: 500;
    color: #021300;
    padding-left: 1rem;
    position: relative;
  }
  .audience-needs li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #0AAD0A;
    font-weight: 700;
  }

  .future-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .future-card {
    padding: 1.75rem;
    background: #F9FAFB;
    border-radius: 12px;
    border: 1px solid #E5E7EB;
  }
  .future-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #0AAD0A;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .future-text {
    font-size: 0.875rem;
    font-weight: 300;
    color: #021300;
    line-height: 1.65;
  }
  .future-footnote {
    font-size: 0.8rem;
    font-weight: 300;
    font-style: italic;
    color: rgba(2,19,0,0.5);
    line-height: 1.6;
    border-left: 3px solid #E5E7EB;
    padding-left: 1rem;
  }

  @media (max-width: 700px) {
    .statement-card { padding: 1.75rem; }
    .audience-grid { grid-template-columns: 1fr; }
    .positioning-block { flex-direction: column; gap: 0.4rem; }
    .future-grid { grid-template-columns: 1fr; }
  }
</style>
